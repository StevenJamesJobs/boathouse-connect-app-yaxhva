{
  "expo": {
    "name": "Boathouse Connect",
    "slug": "BoathouseConnect",
    "owner": "stevenjamesjobs",
    "version": "2.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/SpringAppClip.png",
    "scheme": "boathouseconnect",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-placeholder.png",
      "resizeMode": "cover",
      "backgroundColor": "#87CEEB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stevenjamesjobs.mcloonesboathouseconnect",
      "buildNumber": "2.0.1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"],
        "NSPhotoLibraryUsageDescription": "Boathouse Connect needs access to your photo library so you can upload a profile picture, as well as images for menu items, announcements, special features, upcoming events, recipes, and messages.",
        "NSCameraUsageDescription": "Boathouse Connect needs camera access so you can take photos for your profile picture, menu items, announcements, and other content."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/SpringAppClip.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mcloonesboathouse.GPboathouseconnect",
      "versionCode": 172,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/57b2b2e5-dd37-4d86-a5d4-03c600dda0ca.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Boathouse Connect needs access to your photo library so you can upload a profile picture, as well as images for menu items, announcements, special features, upcoming events, recipes, and messages."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#87CEEB",
          "image": "./assets/images/splash-placeholder.png",
          "imageResizeMode": "cover",
          "dark": {
            "backgroundColor": "#87CEEB",
            "image": "./assets/images/splash-placeholder.png",
            "imageResizeMode": "cover"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/SpringAppClip.png",
          "color": "#ffffff",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "1ab6bb51-f4ea-445b-8c25-cd0c5d0d4fea"
      }
    }
  }
}
