{
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "autoIncrement": true,
      "cache": {
        "disabled": false
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "cache": {
        "disabled": false
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "22.15.0",
      "cache": {
        "disabled": false
      },
      "env": {
        "EXPO_NO_TELEMETRY": "1"
      }
    },
    "production-mcloones": {
      "extends": "production",
      "env": {
        "APP_VARIANT": "mcloones"
      }
    },
    "production-public": {
      "extends": "production",
      "env": {
        "APP_VARIANT": "public"
      }
    }
  },
  "submit": {
    "production": {}
  },
  "cli": {
    "appVersionSource": "remote"
  }
}
